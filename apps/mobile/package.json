{
  "name": "@automatize/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "echo 'Mobile app does not need build for development. Use: pnpm start'",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "clean": "rm -rf .expo node_modules .turbo dist"
  },
  "dependencies": {
    "@automatize/auth": "workspace:*",
    "@automatize/core": "workspace:*",
    "@automatize/storage": "workspace:*",
    "@automatize/sync": "workspace:*",
    "@automatize/ui": "workspace:*",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-navigation/native": "^6.1.9",
    "expo": "^50.0.6",
    "expo-constants": "^15.4.5",
    "expo-dev-client": "^3.3.5",
    "expo-linking": "^6.2.2",
    "expo-router": "^3.4.7",
    "expo-secure-store": "^12.8.1",
    "expo-status-bar": "^1.11.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.73.2",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-web": "~0.19.10",
    "react-native-screens": "^3.29.0"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@babel/core": "^7.23.7",
    "@types/react": "^18.2.48",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
