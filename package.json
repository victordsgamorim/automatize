{
  "name": "automatize",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform invoice management system with offline-first architecture",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@automatize/mobile",
    "dev:mobile:android": "turbo run android --filter=@automatize/mobile",
    "dev:mobile:ios": "turbo run ios --filter=@automatize/mobile",
    "dev:mobile:web": "turbo run web --filter=@automatize/mobile",
    "dev:web": "turbo run dev --filter=@automatize/web",
    "dev:packages": "turbo run dev --filter=@automatize/core --filter=@automatize/ui --filter=@automatize/supabase-auth --filter=@automatize/storage --filter=@automatize/sync",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "scan:deps": "tsx scripts/scan-deps.ts",
    "scan:deps:json": "tsx scripts/scan-deps.ts --json",
    "scan:deps:summary": "tsx scripts/scan-deps.ts --summary",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@automatize/eslint-config": "workspace:*",
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@types/node": "^20.11.5",
    "eslint": "^8.56.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "tsx": "^4.21.0",
    "turbo": "^2.7.3",
    "typescript": "^5.9.0"
  }
}
