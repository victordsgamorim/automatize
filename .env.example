# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.development and fill in the values for your setup
# Never commit .env.development or any actual credentials to version control

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Your Supabase project URL and anonymous key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# DEEP LINKING CONFIGURATION
# ============================================================================
# Scheme used for deep links (password reset, etc)
DEEP_LINK_SCHEME=automatize

# ============================================================================
# API CONFIGURATION
# ============================================================================
# API base URL (for future Supabase Edge Functions and backend API)
API_URL=http://localhost:3000

# ============================================================================
# OBSERVABILITY CONFIGURATION (Optional)
# ============================================================================
# Observability provider to be configured (error tracking, performance monitoring)
# OBSERVABILITY_PROVIDER=

# ============================================================================
# ENVIRONMENT IDENTIFICATION
# ============================================================================
# Current environment: development, staging, or production
ENVIRONMENT=development
