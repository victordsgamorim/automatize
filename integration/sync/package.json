{
  "name": "@automatize/sync",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@automatize/auth": "workspace:*",
    "@automatize/utils": "workspace:*",
    "@automatize/storage": "workspace:*",
    "@react-native-community/netinfo": "catalog:",
    "ky": "^1.1.3",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "react": "catalog:react18",
    "react-native": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0"
  }
}
