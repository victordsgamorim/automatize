{
  "name": "@automatize/storage",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@automatize/auth": "workspace:*",
    "@automatize/utils": "workspace:*",
    "@nozbe/watermelondb": "^0.27.1",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
