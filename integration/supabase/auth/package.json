{
  "name": "@automatize/supabase-auth",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters/web": {
      "types": "./dist/adapters/web.d.ts",
      "import": "./dist/adapters/web.mjs",
      "require": "./dist/adapters/web.js"
    },
    "./adapters/mobile": {
      "types": "./dist/adapters/mobile.d.ts",
      "import": "./dist/adapters/mobile.mjs",
      "require": "./dist/adapters/mobile.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@automatize/core": "workspace:*",
    "@supabase/supabase-js": "^2.39.3",
    "expo-constants": "catalog:",
    "expo-secure-store": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/jsdom": "^28.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "jsdom": "^28.1.0",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "react-native": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0"
  }
}
