{
  "name": "@automatize/sign-in",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.mjs",
      "require": "./dist/web.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@automatize/core": "workspace:*",
    "@automatize/ui": "workspace:*",
    "lucide-react": "catalog:",
    "lucide-react-native": "^0.309.0"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "react": "catalog:react18",
    "react-native": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.0.0",
    "react-native": "^0.73.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  }
}
