{
  "extends": "../../tools/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/**/*.native.ts",
    "src/**/*.native.tsx",
    "src/index.native.ts"
  ]
}
