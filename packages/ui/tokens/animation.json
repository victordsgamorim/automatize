{
  "animation": {
    "fadeSlideIn": {
      "duration": { "$type": "duration", "$value": "600ms" },
      "easing": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "blur": { "$type": "dimension", "$value": "8px" },
      "translateY": { "$type": "dimension", "$value": "20px" }
    },
    "slideRightIn": {
      "duration": { "$type": "duration", "$value": "600ms" },
      "easing": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "blur": { "$type": "dimension", "$value": "8px" },
      "translateX": { "$type": "dimension", "$value": "100px" }
    },
    "testimonialIn": {
      "duration": { "$type": "duration", "$value": "600ms" },
      "easing": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "blur": { "$type": "dimension", "$value": "8px" },
      "translateY": { "$type": "dimension", "$value": "20px" },
      "scale": { "$type": "number", "$value": 0.95 }
    },
    "delay": {
      "$type": "duration",
      "100": { "$value": "100ms" },
      "200": { "$value": "200ms" },
      "300": { "$value": "300ms" },
      "400": { "$value": "400ms" },
      "500": { "$value": "500ms" },
      "600": { "$value": "600ms" },
      "700": { "$value": "700ms" },
      "800": { "$value": "800ms" },
      "900": { "$value": "900ms" },
      "1000": { "$value": "1000ms" },
      "1200": { "$value": "1200ms" },
      "1400": { "$value": "1400ms" }
    }
  }
}
