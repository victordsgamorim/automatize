{
  "name": "@automatize/auth",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./storage/implementations/webTokenStorage": {
      "types": "./dist/storage/implementations/webTokenStorage.d.ts",
      "import": "./dist/storage/implementations/webTokenStorage.mjs",
      "require": "./dist/storage/implementations/webTokenStorage.js"
    },
    "./storage/implementations/mobileTokenStorage": {
      "types": "./dist/storage/implementations/mobileTokenStorage.d.ts",
      "import": "./dist/storage/implementations/mobileTokenStorage.mjs",
      "require": "./dist/storage/implementations/mobileTokenStorage.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@automatize/core": "workspace:*",
    "@supabase/supabase-js": "^2.39.3",
    "expo-constants": "^15.0.1",
    "expo-secure-store": "^12.8.1",
    "react": "^18.2.0",
    "react-native": "^0.74.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@automatize/tsconfig": "workspace:*",
    "@types/react": "^18.2.48",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  }
}
